{
  "manifest_version": 3,
  "name": "ParaNote: Paragraph Annotator",
  "version": "1.0.0",
  "description": "Attach context-aware notes to any paragraph on the web.",
  "permissions": [
    "unlimitedStorage",
    "storage",
    "activeTab",
    "scripting",
    "identity" 
  ],
  "host_permissions": [
    "*://lablabee.com/*",
    "*://*.lablabee.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ParaNote Menu"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://lablabee.com/*", "*://*.lablabee.com/*"],
      "js": ["content/content.js"],
      "css": ["content/styles.css"]
    }
  ],
  "oauth2": {
    "client_id": "400263042707-thop12p3p7g2rrlggpvv8ll2tnboe50h.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  }
}