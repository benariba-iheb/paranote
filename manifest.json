{
  "manifest_version": 3,
  "name": "ParaNote: Paragraph Annotator",
  "version": "2.1",
  "description": "Attach context-aware notes to any paragraph on the web.",
  "permissions": [
    "unlimitedStorage",
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "*://lablabee.com/*",
    "*://*.lablabee.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "ParaNote Menu"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://lablabee.com/*",
        "*://*.lablabee.com/*"
      ],
      "js": [
        "src/content/content.tsx"
      ]
    }
  ],
  "oauth2": {
    "client_id": "YOUR_APP_CLIENT_ID_GOES_HERE",
    "scopes": [
      "openid",
      "email",
      "profile",
      "https://www.googleapis.com/auth/drive.appdata",
      "https://www.googleapis.com/auth/drive.file"
    ]
  }
}