# Copy this file to .env and fill in your Google Cloud Console Client IDs
# One per build target — found in APIs & Services → Credentials

VITE_SUPPORT_CLIENT_ID=your-support-client-id.apps.googleusercontent.com
VITE_LAB_CLIENT_ID=your-lab-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-fallback-client-id.apps.googleusercontent.com
